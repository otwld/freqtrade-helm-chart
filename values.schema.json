{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "mode": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["trade", "dryRun", "webserver", "backtest", "hyperopt", "downloadData"]
        },
        "extraArgs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "schedule": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "cron": {
              "type": "string"
            }
          }
        }
      },
      "required": ["type"]
    },
    "strategy": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "name": {
          "type": "string"
        },
        "mode": {
          "type": "string",
          "enum": ["image", "volume", "initSync"]
        },
        "initSync": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "enabled": {
              "type": "boolean"
            }
          }
        }
      },
      "required": ["mode"]
    },
    "config": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "public": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "timeframe": {
              "type": "string"
            },
            "stake_currency": {
              "type": "string"
            },
            "stake_amount": {},
            "exchange": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "name": {
                  "type": "string"
                }
              }
            }
          }
        },
        "existingSecret": {
          "type": "string"
        },
        "existingSecretKey": {
          "type": "string"
        },
        "externalSecret": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "target": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "name": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "persistence": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "mountPath": {
          "type": "string"
        }
      }
    },
    "api": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      }
    },
    "ui": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "corsOrigins": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "ingress": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "enabled": {
              "type": "boolean"
            }
          }
        }
      }
    },
    "service": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      }
    }
  }
}
